{
    "name": "sales-photo-tracker",
    "version": "1.0.0",
    "description": "Telegram bot that automates daily sales data collection from multiple offline stores",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "start:poll": "node dist/index.js",
        "set-webhook": "npx tsx scripts/set-webhook.ts",
        "remove-webhook": "npx tsx scripts/set-webhook.ts --remove",
        "get-oauth-token": "npx tsx scripts/get-oauth-token.ts",
        "test": "vitest --run"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "keywords": [],
    "license": "ISC",
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "dotenv": "^17.4.0",
        "googleapis": "^171.4.0",
        "grammy": "^1.41.1"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@vercel/node": "^5.7.0",
        "fast-check": "^4.6.0",
        "typescript": "^6.0.2",
        "vercel": "50.38.3",
        "vitest": "^4.1.2"
    }
}
